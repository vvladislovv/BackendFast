# Database
DATABASE_URL=postgresql+asyncpg://backend_user:backend_password@localhost:5432/backend_db

# Security
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ADMIN_IDS=123456789,987654321

# Email (Beget SMTP)
EMAIL_HOST=smtp.beget.com
EMAIL_PORT=587
EMAIL_USER=info@hacktaika.ru
EMAIL_PASSWORD=your-email-password-here
EMAIL_FROM=info@hacktaika.ru
EMAIL_ADMIN=admin@hacktaika.ru

# Application
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# Note: Python 3.13 required (not 3.14)
